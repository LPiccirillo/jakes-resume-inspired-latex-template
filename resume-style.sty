%--------------------------------------------------------
% resume_style.sty
% Custom LaTeX style file for CV formatting
% Author: Luigi Piccirillo
%--------------------------------------------------------

% FONT AND CHARACTER ENCODING
% fontenc with T1 encoding improves support for accented
% characters and correct text extraction from the PDF.
% lmodern loads the Latin Modern font family, which provides
% a clean professional appearance and better compatibility
% with T1 encoding.
\RequirePackage[T1]{fontenc}
\RequirePackage{lmodern}

% PAGE LAYOUT
% fullpage simplifies page margin configuration.
% The "empty" option removes default headers and footers
% generated by the package.
\RequirePackage[empty]{fullpage}

% SECTION FORMATTING
% titlesec allows custom formatting of section headings
% such as Education, Experience and Skills.
\RequirePackage{titlesec}

% COLOUR SUPPORT
% xcolor extends the standard LaTeX colour capabilities.
% The dvipsnames option enables a predefined collection
% of named colours (e.g., NavyBlue, RoyalBlue, Gray,
% ForestGreen), which can be used for text, rules, icons
% or other document elements.
% Compared with the basic color package, xcolor provides
% more advanced colour management and a larger colour set.
% In this CV, it is mainly used to customise section rules,
% headings or visual elements while keeping a professional
% appearance.
\RequirePackage[dvipsnames]{xcolor}

% SYMBOLS AND SPECIAL CHARACTERS
% latexsym provides additional LaTeX symbols.
% marvosym provides extra symbols commonly used in CVs,
% such as phone, email and location icons.
\RequirePackage{latexsym}
\RequirePackage{marvosym}

% PAGE AND TEXT MANIPULATION
% changepage allows local adjustments of text width and
% margins inside specific parts of the document.
% verbatim allows verbatim text blocks where LaTeX commands
% are not interpreted.
\RequirePackage{changepage}
\RequirePackage{verbatim}

% LIST FORMATTING
% enumitem provides advanced control over itemize/enumerate
% environments.
% Used to customise bullet spacing, indentation and labels,
% which is important for compact CV bullet points.
\RequirePackage{enumitem}

% HYPERLINKS
% hyperref creates clickable links in the PDF.
% hidelinks removes coloured boxes and underlining around
% links, keeping a clean CV appearance.
\RequirePackage[hidelinks]{hyperref}

% PAGE STYLE
% fancyhdr provides custom control over headers and footers.
% Used here to completely remove default header/footer
% elements and create a clean one-page CV layout.
\RequirePackage{fancyhdr}

% LANGUAGE SUPPORT
% babel with the english option configures typographic
% conventions, hyphenation rules and language-specific
% formatting for English documents.
\RequirePackage[english]{babel}

% TABLES AND COLUMN LAYOUT
% tabularx provides flexible-width tables that automatically
% adjust column sizes.
% Used for structured CV elements with aligned text.
\RequirePackage{tabularx}

% ICONS
% fontawesome5 provides modern Font Awesome icons.
% Used in the header for contact information such as:
% phone, email, LinkedIn and GitHub.
\RequirePackage{fontawesome5}

% MULTIPLE COLUMNS
% multicol allows content to be arranged in multiple columns.
% Mainly useful for compact Skills or Languages sections.
\RequirePackage{multicol}

% GRAPHICS
% graphicx enables insertion and scaling of images.
% Used for adding the signature image at the end of the CV.
\RequirePackage{graphicx}

% MULTICOL SETTINGS
% Reduces vertical space between multiple columns.
% Smaller values create a more compact layout.
\setlength{\multicolsep}{0pt}

% Reduces horizontal spacing between columns.
\setlength{\columnsep}{8pt}

% PDF ACCESSIBILITY AND ATS COMPATIBILITY
% glyphtounicode improves character mapping inside the PDF.
% \pdfgentounicode=1 ensures that generated PDFs contain
% proper Unicode mappings, making text selectable and
% readable by ATS (Applicant Tracking Systems).
\input{glyphtounicode}
\pdfgentounicode=1

% PAGE STYLE CONFIGURATION
% Removes all default header and footer elements.
\pagestyle{fancy}
\fancyhf{}
% Removes footer content.
\fancyfoot{}
% Controls distance between footer and page content.
% A smaller value keeps the layout compact.
\setlength{\footskip}{5pt}
% Removes the horizontal line under the header.
\renewcommand{\headrulewidth}{0pt}
% Removes the horizontal line above the footer.
\renewcommand{\footrulewidth}{0pt}

% PAGE MARGIN ADJUSTMENTS
% The following commands modify the default LaTeX margins
% to maximise usable space on the page.
% Negative values enlarge the text area, which is common
% in one-page CV templates.
\addtolength{\oddsidemargin}{-0.6in}
\addtolength{\evensidemargin}{-0.5in}
\addtolength{\textwidth}{1.19in}
% Moves the page content slightly upwards.
\addtolength{\topmargin}{-.7in}
% Increases the usable vertical space.
\addtolength{\textheight}{1.4in}

% URL STYLE
% Keeps URLs visually consistent with the surrounding text.
% Since hyperref uses hidden links, this mainly affects
% font rendering of URLs.
\urlstyle{same}

% TEXT ALIGNMENT SETTINGS
% raggedbottom prevents LaTeX from stretching vertical
% spaces to make pages have equal height.
% raggedright disables full justification and avoids large
% spaces between words.
% tabcolsep controls horizontal padding inside tables.
% Setting it to zero creates tighter CV alignment.
\raggedbottom
\raggedright
\setlength{\tabcolsep}{0in}

% SECTION HEADING FORMAT
% Customises section titles (Education, Experience, Skills).
% Format:
% - removes extra space before the title.
% - aligns title to the left.
% - uses large bold font.
% - adds a horizontal rule below each section.
% \vspace{-5pt} reduces spacing after the line to keep the
% CV compact.
\titleformat{\section}{
  \vspace{-1pt}\raggedright\large\bfseries
}{}{0em}{}[\color{black}\titlerule \vspace{-2pt}]

%--------------------------------------------------------
% CUSTOM COMMANDS
% These macros define reusable formatting commands used
% throughout the CV. Their purpose is to keep the layout
% consistent while reducing repetitive LaTeX code.
%--------------------------------------------------------

% Creates a single bullet point inside an itemized list.
% Arguments:
%   #1 = text of the bullet point.
% Behaviour:
% - \item creates the list item.
% - \small slightly reduces the font size.
% - \vspace{-2pt} removes a small amount of vertical
%   space after the item, making the CV more compact.
\newcommand{\resumeItem}[1]{
  \item\small{
    {#1 \vspace{0pt}}}}

% \classesList{a}{b}{c}{d}
% Legacy macro inherited from the original template.
% Concatenates four arguments into a single bullet point.
% This command is currently unused and can safely be
% removed unless needed in future versions of the CV.
\newcommand{\classesList}[4]{
    \item\small{
        {#1 #2 #3 #4 \vspace{0pt}}}}

% \resumeSubheading{Title}{Date}{Institution}{Location}
% Creates the header for a professional experience entry.
% Layout:
%   Title                                Date
%   Institution                          Location
% Arguments:
%   #1 = title (bold)
%   #2 = date (small bold)
%   #3 = institution/company (small italic)
%   #4 = location (small italic)
% Implementation details:
% - tabular* spans the entire text width.
% - l@{\extracolsep{\fill}}r creates two columns:
%       left column  -> left aligned
%       right column -> right aligned
%   The \extracolsep{\fill} command inserts elastic
%   horizontal space between the columns, automatically
%   pushing the date to the right margin.
% - \vspace{-2pt} slightly reduces the space above the entry.
% - \vspace{-7pt} reduces the space below the table 
%   before the bullet list begins.
\newcommand{\resumeSubheading}[4]{
  \vspace{0pt}\item
    \begin{tabular*}{1.0\textwidth}[t]{l@{\extracolsep{\fill}}r}
      \textbf{#1} & \textbf{\small #2} \\
      \textit{\small#3} & \textit{\small #4} \\
    \end{tabular*}\vspace{-4pt}}

% \resumeSubheadingEdu{Title}{Date}{Institution}{Location}{Additional information}
% Creates the header for an education entry.
% Layout:
%   Degree title                         Date
%   University                           Location
%   Additional information
% Arguments:
%   #1 = degree title (bold)
%   #2 = date/period (small bold)
%   #3 = university/institution (small italic)
%   #4 = location (small italic)
%   #5 = additional information, such as GPA, final grade,
%        credits or academic details (small italic)
% Implementation details:
% - tabular* spans the entire text width.
% - l@{\extracolsep{\fill}}r creates two columns:
%       left column  -> left aligned
%       right column -> right aligned
%   The \extracolsep{\fill} command inserts elastic
%   horizontal space between the columns, automatically
%   pushing the date and location to the right margin.
% - The additional information (#5) is placed on a separate
%   third row using \multicolumn{2}{l}, allowing it to span
%   the full width of the table.
% - \textbf{} is used for the degree title and date to create
%   visual hierarchy.
% - \textit{} is used for the university, location and
%   additional academic information to distinguish secondary
%   details.
% - \vspace{-2pt} slightly reduces the space above the entry.
% - \vspace{-7pt} reduces the space below the table before
%   the bullet list begins, keeping the CV compact.
\newcommand{\resumeSubheadingEdu}[5]{
  \vspace{0pt}\item
    \begin{tabular*}{1.0\textwidth}[t]{l@{\extracolsep{\fill}}r}
      \textbf{#1} & \textbf{\small #2} \\
      \textit{\small #3} & \textit{\small #4} \\
      \multicolumn{2}{l}{\textit{\small #5}} \\
    \end{tabular*}\vspace{-4pt}}

% \resumeSubSubheading{Text}{Date}
% Creates a simplified two-column heading.
% Layout:
%   Text                                Date
% Both fields are printed in small italic font.
% This macro is included in the original template but is
% only occasionally used.
\newcommand{\resumeSubSubheading}[2]{
    \item
    \begin{tabular*}{0.97\textwidth}{l@{\extracolsep{\fill}}r}
      \textit{\small#1} & \textit{\small #2} \\
    \end{tabular*}\vspace{-4pt}}

% \resumeProjectHeading{Project}{Date}
% Creates the heading for a project entry.
% Layout:
%   Project name                        Date
% The project name is printed in small bold font, while the
% date is displayed in small bold font.
% The table width is set to 1.001\textwidth to avoid
% occasional alignment issues caused by rounding.
\newcommand{\resumeProjectHeading}[2]{
    \item
    \begin{tabular*}{1.001\textwidth}{l@{\extracolsep{\fill}}r}
      \textbf{\small #1} & \textbf{\small #2}\\
    \end{tabular*}\vspace{-4pt}}

% \resumeProfile{Profile description}
% Creates a compact profile/summary section at the top of
% the CV, usually placed below the header and before
% Experience or Education.
% The section contains a short professional description
% highlighting:
% - academic background;
% - technical expertise;
% - research interests;
% - career objectives.
% Arguments:
%   #1 = profile text
% Implementation details:
% - \small reduces the font size to fit a concise summary.
% - \vspace{-2pt} reduces spacing before the paragraph.
% - \noindent removes paragraph indentation.
\newcommand{\resumeProfile}[1]{
    \vspace{0pt}
    \small
    \noindent #1
    \vspace{0pt}}

% \resumeProject{Title}{Date}{Metadata}{Repository}{Description}{Technologies}
% Creates a project entry with:
%   Title                                Date
%   Metadata                             Repository
%   Description
%   Technologies
% Arguments:
%   #1 = project title (bold)
%   #2 = date (small bold, right aligned)
%   #3 = metadata (small italic, below title)
%   #4 = repository/link label (small italic, right aligned below date)
%   #5 = project description
%   #6 = technologies used
% Implementation details:
% - tabular* creates a two-column layout.
% - l@{\extracolsep{\fill}}r aligns title/metadata left and date/repository right.
% - Metadata is placed below the title.
% - Repository is placed below the date.
% - \textbf{} highlights title and date.
% - \footnotesize keeps description and technologies compact.
% - adjustwidth creates indentation for project details.
\newcommand{\resumeProject}[6]{
  \vspace{0pt}\item
    \begin{tabular*}{1.0\textwidth}[t]{l@{\extracolsep{\fill}}r}
      \textbf{#1} & \textbf{\small #2} \\
      \textit{\small #3} & \textit{\small #4} \\
    \end{tabular*}
    \begin{adjustwidth}{0.3cm}{0cm}
      {\footnotesize #5}\\
      {\footnotesize \textit{Technologies:} #6}
    \end{adjustwidth}
    \vspace{1pt}}

% \resumeSkillInline{Title}{Text}
% Creates a compact skills category entry.
% Layout:
%   Category title:
%   Skill list
% Arguments:
%   #1 = category title (bold)
%   #2 = skill description
% Implementation details:
% - \textbf{} highlights the category name.
% - \footnotesize reduces the text size for compact CV formatting.
% - \adjustwidth creates a small indentation for the skill list.
% - No vertical space is inserted between the title and content,
%   keeping the category visually compact.
% - \vspace{2pt} adds a small separation between different
%   skill categories.
\newcommand{\resumeSkill}[2]{
    \textbf{\footnotesize #1}:\\[-2pt]
    \begin{adjustwidth}{0.3cm}{0cm}
        {\footnotesize #2}
    \end{adjustwidth}
    \vspace{1pt}}

% \resumeSkillInline{Title}{Text}
% Creates a compact skill entry with title and description
% displayed on the same line.
% Layout:
%   Category title: Description
% Arguments:
%   #1 = category title (bold)
%   #2 = description text (small font)
% Implementation details:
% - \textbf{} highlights the category title.
% - \footnotesize reduces the text size for compact CV formatting.
% - The whole entry remains on a single line, unlike
%   \resumeSkill, which places the description below the title.
% - \vspace{2pt} adds a small vertical separation between entries.
\newcommand{\resumeSkillInline}[2]{
    \textbf{\footnotesize #1}: {\footnotesize #2}
    \vspace{0pt}}

% \resumeSubItem{text}
% Creates a bullet point using \resumeItem and then
% removes an additional 4pt of vertical space.
% Intended for nested bullet lists.
% Currently unused in this CV.
\newcommand{\resumeSubItem}[1]{\resumeItem{#1}\vspace{-1pt}}

% Redefines the default bullet symbols used by itemize.
% The standard LaTeX bullet is replaced with a much
% smaller bullet centred vertically with the text line,
% producing a cleaner and more compact appearance.
\renewcommand\labelitemi{$\vcenter{\hbox{\tiny$\bullet$}}$}
\renewcommand\labelitemii{$\vcenter{\hbox{\tiny$\bullet$}}$}

% Commands for opening and closing the lists that contain
% CV entries (Experience, Education, etc.).
% The list:
% - has no visible bullets;
% - has no left indentation;
% allowing each entry to behave like a standalone block.
\newcommand{\resumeSubHeadingListStart}{\begin{itemize}[leftmargin=0.0in, label={}]}
\newcommand{\resumeSubHeadingListEnd}{\end{itemize}}

% Commands for opening and closing the bullet-point lists
% describing each experience or education entry.
% \resumeItemListEnd additionally removes 5pt of vertical
% space after the list to maintain a compact layout.
\newcommand{\resumeItemListStart}{\begin{itemize}}
\newcommand{\resumeItemListEnd}{\end{itemize}\vspace{-3pt}}

% PUBLICATIONS
% Bibliography support using APA 7th style.
\RequirePackage{csquotes}

% biblatex manages references from an external .bib file.
% The APA style automatically formats:
% - authors;
% - publication year;
% - article title;
% - journal;
% - volume/issue;
% - pages;
% - DOI.
\RequirePackage[
    backend=biber,
    style=apa,
    sorting=ydnt
]{biblatex}

% Removes "References" default heading when using custom sections.
\defbibheading{pubheading}{}

% \resumePublication{keyword}
% Prints a single publication entry as a bullet point.
% Arguments:
%   #1 = citation key from the .bib file
\newcommand{\resumePublication}[1]{%
    \item \small\fullcite{#1}}